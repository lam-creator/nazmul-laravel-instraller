// Web Installer Routes
use App\Http\Controllers\InstallController;
Route::prefix('install')->group(function () {
    Route::get('/', [InstallController::class, 'step1'])->name('install.step1');
    Route::post('/step2', [InstallController::class, 'step2'])->name('install.step2');
    Route::post('/finish', [InstallController::class, 'finish'])->name('install.finish');
});